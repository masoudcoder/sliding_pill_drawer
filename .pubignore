example/linux/
example/.flutter-plugins
example/.flutter-plugins-dependencies
example/pubspec.lock

# Repo automation, not relevant to pub.dev consumers.
.github/
.idea/
*.iml

# Capture instructions are for contributors only.
doc/CAPTURE.md

